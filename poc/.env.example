# =============================================================================
# OmniClip POC - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# IMPORTANT: Node >= 22.21.0 required (rettiwt-api v7 dependency)
# =============================================================================

# -----------------------------------------------------------------------------
# XHS (Xiaohongshu / RED) Cookies
# -----------------------------------------------------------------------------
# How to get:
#   1. Open https://www.xiaohongshu.com in Chrome and log in
#   2. F12 → Network → find any request to edith.xiaohongshu.com
#   3. Right-click the request → Copy → Copy as cURL
#   4. Extract the full Cookie header value (everything after -H 'Cookie: ')
#   5. Paste below as a single line (no quotes needed)
#
# The cookie string must contain at least "a1=..." (MANDATORY).
# web_session, webId, gid, xsecappid etc. are recommended for full access.
# Cookies expire after ~7 days — re-extract when you get 461 errors.
# -----------------------------------------------------------------------------
XHS_COOKIES=your_full_cookie_string_here

# -----------------------------------------------------------------------------
# Twitter / X - API Key
# -----------------------------------------------------------------------------
# How to get (recommended - browser extension):
#   1. Install "X Auth Helper" Chrome extension
#      https://chromewebstore.google.com/detail/x-auth-helper/igpkhkjmpdecacocghpgkghdcmcmpfhp
#   2. Open incognito mode → log into x.com
#   3. Click extension → "Get Key" → copy the API_KEY
#   4. Paste below
#
# The API_KEY is a base64-encoded cookie string. It lasts ~5 years unless
# you log out or change your password.
# -----------------------------------------------------------------------------
TWITTER_API_KEY=your_base64_api_key_here

# Alternative: raw cookies (fallback if you don't want the extension)
# F12 → Application → Cookies → x.com → copy auth_token and ct0
# TWITTER_AUTH_TOKEN=your_auth_token_here
# TWITTER_CT0=your_ct0_value_here
