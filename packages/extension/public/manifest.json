{
  "manifest_version": 3,
  "name": "OmniClip Content Aggregator",
  "version": "0.1.0",
  "description": "Collect content from Xiaohongshu and X/Twitter to your OmniClip dashboard",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://edith.xiaohongshu.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.xiaohongshu.com/*"],
      "js": ["content/xiaohongshu/interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start",
      "exclude_matches": [
        "https://www.xiaohongshu.com/login*",
        "https://www.xiaohongshu.com/payment*"
      ]
    },
    {
      "matches": ["https://www.xiaohongshu.com/*"],
      "js": ["bridge/bridge.js"],
      "world": "ISOLATED",
      "run_at": "document_start",
      "exclude_matches": [
        "https://www.xiaohongshu.com/login*",
        "https://www.xiaohongshu.com/payment*"
      ]
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content/twitter/interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start",
      "exclude_matches": ["https://x.com/i/flow/login*", "https://twitter.com/i/flow/login*"]
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["bridge/bridge.js"],
      "world": "ISOLATED",
      "run_at": "document_start",
      "exclude_matches": ["https://x.com/i/flow/login*", "https://twitter.com/i/flow/login*"]
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
